-1518773553398-650c184e0bb3%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1400%26q%3D80&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1518773553398-650c184e0bb3%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1400%26q%3D80&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1518773553398-650c184e0bb3%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1400%26q%3D80&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1518773553398-650c184e0bb3%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1400%26q%3D80&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1518773553398-650c184e0bb3%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1400%26q%3D80&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1518773553398-650c184e0bb3%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1400%26q%3D80&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1518773553398-650c184e0bb3%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1400%26q%3D80&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1518773553398-650c184e0bb3%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1400%26q%3D80&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1518773553398-650c184e0bb3%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1400%26q%3D80&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1518773553398-650c184e0bb3%3Fauto%3Dformat%26fit%3Dcrop%26w%3D1400%26q%3D80&amp;w=3840&amp;q=75\"/></div><div class=\"space-y-4 p-5\"><div class=\"flex items-center justify-between gap-3\"><h3 class=\"text-lg font-semibold text-slate-950\">Design System Toolkit</h3><span class=\"text-sm text-slate-500\">2023</span></div><p class=\"text-sm leading-6 text-slate-700\">Shared component system and docs for product teams, with accessibility guardrails built in.</p><ul class=\"flex flex-wrap gap-2\" aria-label=\"Design System Toolkit technologies\"><li class=\"rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700\">Next.js</li><li class=\"rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700\">Storybook</li><li class=\"rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700\">Tailwind</li><li class=\"rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700\">Playwright</li></ul><div class=\"flex gap-4 pt-1 text-sm font-semibold\"><a class=\"text-slate-900 underline-offset-4 hover:underline\" href=\"https://github.com/louismau/design-system-toolkit\" target=\"_blank\" rel=\"noreferrer noopener\">GitHub</a><a class=\"text-slate-900 underline-offset-4 hover:underline\" href=\"https://example.com/design-system-toolkit\" target=\"_blank\" rel=\"noreferrer noopener\">Live Demo</a></div></div></article></div></div></div></section><section id=\"contact\" class=\"bg-white py-20\"><div class=\"mx-auto w-full max-w-3xl px-4 sm:px-6 lg:px-8\"><p class=\"text-xs font-semibold uppercase tracking-[0.18em] text-slate-500\">Contact</p><h2 class=\"mt-2 text-3xl font-semibold text-slate-950 sm:text-4xl\">Let us build something meaningful.</h2><p class=\"mt-4 text-base text-slate-700\">Share a project idea, collaboration request, or photo inquiry.</p><div class=\"mt-8\"><form class=\"space-y-4 rounded-2xl border border-slate-200 bg-white p-6\"><div class=\"grid gap-4 sm:grid-cols-2\"><label class=\"flex flex-col gap-2 text-sm font-medium text-slate-800\">Name<input required=\"\" class=\"rounded-xl border border-slate-300 px-3 py-2 outline-none ring-offset-2 focus:border-slate-500 focus:ring-2 focus:ring-slate-300\" name=\"name\" value=\"\"/></label><label class=\"flex flex-col gap-2 text-sm font-medium text-slate-800\">Email<input required=\"\" type=\"email\" class=\"rounded-xl border border-slate-300 px-3 py-2 outline-none ring-offset-2 focus:border-slate-500 focus:ring-2 focus:ring-slate-300\" name=\"email\" value=\"\"/></label></div><label class=\"flex flex-c